# ── Required ─────────────────────────────────────────────────────────────────

# Gemini API key (free tier works fine — get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail address used to SEND the report
GMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your regular password — see README for how to create one)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address that will RECEIVE the reports (can be the same as GMAIL_ADDRESS,
# or a different address like a spouse's email)
REPORT_RECIPIENT=parent@gmail.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Browser whose cookies to use for YouTube authentication (chrome or firefox)
BROWSER=chrome

# Send an immediate alert email the moment a high-risk video is detected
HIGH_RISK_IMMEDIATE_ALERT=true

# Maximum number of videos to pull from history per run
MAX_VIDEOS_PER_RUN=200
